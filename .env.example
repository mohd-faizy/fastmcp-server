# Advanced RAG Systems - environment template
# Copy to .env and fill only the services you plan to use.

# Required only for notebooks/scripts that call an LLM.
# Groq has a free developer tier and is the default provider for this course.
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant

# --- Popular Commercial LLM Providers ---
# OpenAI
OPENAI_API_KEY=sk-...

# Google (Gemini)
GOOGLE_API_KEY=AIza...

# Azure OpenAI
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# --- Open Source / Free Tier APIs ---
# Hugging Face (Free tier available)
HUGGINGFACE_API_KEY=hf_...
HUGGINGFACEHUB_API_TOKEN=hf_...

# Together AI (Free credits available)
TOGETHER_API_KEY=...

# Cohere (Free trial tier available)
COHERE_API_KEY=...

# Mistral AI (Free tier available)
MISTRAL_API_KEY=...

# --- Search / External Tools ---
# Tavily Search API
TAVILY_API_KEY=tvly-...

# SERP API (Google Search)
SERPAPI_API_KEY=...

# Local embedding model used across the course. No API key required.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional: Module 11 capstone project 2 tuning.
MODULE_11_COLLECTION=module_11_research_rag
MODULE_11_CHROMA_DIR=./chroma_module_11_db
MODULE_11_RETRIEVAL_K=6
MODULE_11_RERANK_TOP_N=5
RERANKER_MODEL=cross-encoder/ms-marco-TinyBERT-L-2-v2

# Optional: LangSmith tracing for debugging and monitoring.
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=Advanced-RAG-Systems

# Optional: Neo4j for the Graph RAG notebook/capstone extensions.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password



